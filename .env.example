# ============================================================
#  JobFounder - Configuration File
#  Copy this file to .env and fill in your values
# ============================================================

# -- EMAIL SETTINGS --
# Use a Gmail address with an App Password (NOT your real password)
# How to get an App Password:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: myaccount.google.com > Security > App Passwords
#   3. Create a new App Password for "Mail" > copy the 16-char code
SENDER_EMAIL=your_gmail@gmail.com
SENDER_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
RECIPIENT_EMAIL=your_email@gmail.com

# -- SCHEDULE --
# What time to run the scan every day (24h format)
DAILY_TIME=08:00

# -- JOB SEARCH --
SEARCH_LOCATION=Maroc
# Leave empty = auto-detect from your CV
# Or fill with comma-separated keywords: Python,Django,Data Science
SEARCH_KEYWORDS=
MAX_JOBS_PER_SOURCE=30
# Minimum match % to include a job in your digest (0-100)
MIN_MATCH_SCORE=5

# -- PLATFORMS TO SCRAPE --
ENABLE_REKRUTE=true
ENABLE_EMPLOIMA=false
ENABLE_INDEED=true
ENABLE_LINKEDIN=true
ENABLE_WELCOMEJUNGLE=true

# -- AUTO APPLY --
# Set to true to automatically apply to jobs (use with caution)
AUTO_APPLY=false
REKRUTE_EMAIL=
REKRUTE_PASSWORD=
INDEED_EMAIL=
INDEED_PASSWORD=

# -- CV PATH --
CV_PATH=cv/cv.pdf
